cgrep() {
  if [ $# -eq 0 ]; then
    echo "usage: git cgrep <grep-args...>"
    return 2
  fi

  git diff --unified=0 --no-color dev... |
    awk '
      /^diff --git/ {
        file=$4
        sub("^b/","",file)
        next
      }

      /^@@/ {
        # Extract the "+<start>" part from: @@ -a,b +c,d @@
        h=$0
        sub(/^@@[^+]*\+/, "", h)     # drop everything through the "+"
        sub(/[, ].*$/, "", h)       # keep only the starting line number
        line = h + 0
        next
      }

      /^[+-][^+-]/ {
        p=file
        if (length(p) > 60) p = "…" substr(p, length(p)-59)
        printf "%s:%d:%s\n", p, line++, substr($0,2)
      }
    ' |
    grep "$@"
}
